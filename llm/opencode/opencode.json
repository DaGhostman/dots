{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gpt-oss-20b": {
          "name": "gpt-oss-20b"
        },
        "nemotron": {
          "name": "nemotron"
        },
        "qwen3-3.5-35b-a3b": {
          "name": "Qwen3.5 35b A3b MOE"
        },
        "kimi": {
          "name": "Kimi Linear"
        },
        "glm-4.7-flash": {
          "name": "GLM 4.7 Flash"
        },
        "hypernova": {
          "name": "Hypernova"
        },
        "qwen3-3.5-0.8b": {
          "name": "Qwen3.5 0.8b"
        },
        "qwen3-3.5-9b": {
          "name": "Qwen3.5 9b"
        },
        "lfm2-24b-a2b": {
          "name": "LFM2 24B A2B"
        },
        "lfm2.5-1.2b": {
          "name": "LFM2.5 1.2B (Thinking)"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "MiniMax": {
        "type": "local",
        "command": [
            "uvx",
            "minimax-mcp",
            "-y"
        ],
        "enabled": true,
        "environment": {
            "MINIMAX_API_HOST": "https://api.minimax.io",
            "MINIMAX_MCP_BASE_PATH": "/tmp/MiniMax",
            "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}"
        }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "title": {
      "model": "llama-cpp/lfm2.5-1.2b"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
  ]
}
