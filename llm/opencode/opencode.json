{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-3.5-35b-a3b": {
          "name": "Qwen3.5 35b A3b MOE"
        },
        "qwen3-3.5-0.8b": {
          "name": "Qwen3.5 0.8b"
        },
        "qwen3-3.5-9b": {
          "name": "Qwen3.5 9b"
        },
        "nomic-embed-text": {
          "name": "nomic-embed-text"
        }
      }
    }
  },
  "mcp": {
    "tree-sitter-analyzer": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "--from",
        "tree-sitter-analyzer[mcp]",
        "tree-sitter-analyzer-mcp"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "rag": {
        "type": "remote",
        "url": "http://localhost:3100/mcp",
        "enabled": true
    },
    "mcp-tasks": {
        "type": "local",
        "enabled": true,
        "command": ["npx", "-y", "mcp-tasks"],
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "plugin": [
    "opencode-mem@^2.11",
    "@mohak34/opencode-notifier@latest",
    "opencode-codebase-index@^0.5.1",
    "openrtk",
  ]
}
